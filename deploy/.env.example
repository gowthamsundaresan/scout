# Production env for /opt/scout/.env — the one file managed by hand on the box.
# Shared by all services via compose env_file; secrets blank here.

# --- Public hostnames (Caddy; sslip.io from the box IP, e.g. gateway.65-108-1-2.sslip.io) ---
GATEWAY_HOST=gateway.<ip-dashed>.sslip.io
API_HOST=api.<ip-dashed>.sslip.io

# --- scout-gateway (Fastify bus) ---
SERVER_PORT=3001
SERVER_HOST=0.0.0.0
DATABASE_URL=            # Atlas, scout-gateway db
ADMIN_SECRET=
JWT_SECRET=
FORWARD_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- scout monorepo services ---
SUPERMEMORY_BASE_URL=http://supermemory:6767
SUPERMEMORY_API_KEY=     # printed by supermemory on first boot; read from the volume
OPENROUTER_API_KEY=
SCOUT_GATEWAY_URL=http://gateway:3001
SCOUT_GATEWAY_ADMIN_SECRET=   # = ADMIN_SECRET above
SCOUT_DASHBOARD_URL=     # Vercel prod URL, for the TG ping link
TEMPORAL_ADDRESS=temporal:7233
EVALS_PORT=8788
EVALS_RECEIVE_URL=http://evals-receiver:8788/receive
MONGO_URI=               # Atlas, scout-indexer db
INGEST_SECRET=           # bearer for @scout/api (dashboard ops + extension push)
EXA_API_KEY=
SEARCH_TARGET_COUNT=10
MAX_DYNAMIC_SEARCHES_PER_DAY=2
SEARCH_COOLDOWN_DAYS=7

# --- supermemory's own LLM (extraction/memory agent, via OpenRouter) ---
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=          # = OPENROUTER_API_KEY
OPENAI_MODEL=anthropic/claude-sonnet-4.6
OPENAI_FAST_MODEL=anthropic/claude-haiku-4.5

# --- infra ---
POSTGRES_PASSWORD=       # temporal's postgres, internal only
