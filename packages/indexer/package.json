{
	"name": "@scout/indexer",
	"version": "0.1.0",
	"description": "Scout indexer — source-agnostic ingest worker (clean → processing-agent → memory)",
	"private": true,
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"dev": "tsx watch --clear-screen=false ./src/worker.ts",
		"start": "tsx ./src/worker.ts",
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest run --passWithNoTests --testTimeout=60000",
		"lint": "eslint src test",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@mozilla/readability": "^0.5.0",
		"@scout/memory": "*",
		"dotenv": "^16.4.5",
		"exa-js": "^2.15.0",
		"jsdom": "^24.1.3",
		"langfuse": "^3.38.0",
		"mongoose": "^8.6.0",
		"openai": "^6.44.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/jsdom": "^21.1.7",
		"@types/node": "^20.11.24",
		"mongodb-memory-server": "^10.2.0",
		"tsx": "^4.7.1",
		"typescript": "^5.3.3",
		"vitest": "^3.2.4"
	}
}
