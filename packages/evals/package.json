{
	"name": "@scout/evals",
	"version": "0.1.0",
	"description": "Scout evals — digest judge + observer closing the ceo feedback loop via Temporal",
	"private": true,
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"dev": "tsx watch --clear-screen=false ./src/temporal/worker.ts",
		"worker": "tsx ./src/temporal/worker.ts",
		"receiver": "tsx ./src/receiver/server.ts",
		"bootstrap": "tsx ./src/bootstrap.ts",
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest run --passWithNoTests --testTimeout=60000",
		"lint": "eslint src test",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@scout/llm": "*",
		"@scout/memory": "*",
		"@temporalio/activity": "^1.11.5",
		"@temporalio/client": "^1.11.5",
		"@temporalio/worker": "^1.11.5",
		"@temporalio/workflow": "^1.11.5",
		"dotenv": "^16.4.5",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@scout/agents": "*",
		"@types/node": "^20.11.24",
		"tsx": "^4.7.1",
		"typescript": "^5.3.3",
		"vitest": "^3.2.4"
	}
}
