{
	"name": "@scout/tg-ingress",
	"version": "0.1.0",
	"description": "Scout tg-ingress — long-polls Telegram for digest replies and posts them to the gateway",
	"private": true,
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"dev": "tsx watch --clear-screen=false ./src/index.ts",
		"start": "tsx ./src/index.ts",
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest run --passWithNoTests --testTimeout=60000",
		"lint": "eslint src test",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"dotenv": "^16.4.5"
	},
	"devDependencies": {
		"@types/node": "^20.11.24",
		"tsx": "^4.7.1",
		"typescript": "^5.3.3",
		"vitest": "^3.2.4"
	}
}
